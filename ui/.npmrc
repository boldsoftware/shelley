# Minimum release age: don't install packages published less than 7 days ago.
# Mitigates supply-chain attacks from compromised/malicious new releases.

# npm (days)
min-release-age=7
ignore-scripts=true

# pnpm (minutes; 7 days = 10080)
minimum-release-age=10080

# Allow recent @xterm betas (kitty keyboard protocol support not yet in a stable release).
minimum-release-age-exclude[]=@xterm/xterm
minimum-release-age-exclude[]=@xterm/addon-fit
minimum-release-age-exclude[]=@xterm/addon-web-links
